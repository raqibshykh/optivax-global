# Development environment — mock server intercepts all /saas/v1/* fetch calls
# by pathname. Leaving VITE_API_URL empty forces relative paths so the mock
# server's startsWith("/saas/v1/") checks always match.
# For production, set this to your real API base URL (e.g. https://api.optivax.com)
VITE_API_URL=
VITE_API_BASE=
VITE_SSE_PATH=/notifications/stream
