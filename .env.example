# Copy this file to .env and fill in values for your environment.
#
# DEVELOPMENT (mock server):
#   Leave VITE_API_URL empty. The in-browser mock server intercepts fetch
#   by pathname, so relative paths (/saas/v1/...) are required.
#
# PRODUCTION:
#   Set VITE_API_URL to your real API origin. import.meta.env.DEV will be
#   false in a production build, so getBaseUrl() will use this value.
VITE_API_URL=
VITE_API_BASE=
VITE_SSE_PATH=/notifications/stream
VITE_STRIPE_PUBLISHABLE_KEY=
